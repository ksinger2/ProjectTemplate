# =============================================
# .claudeignore — Template for production apps
# Keeps context focused by excluding generated,
# binary, and non-essential files.
# =============================================

# ---------------------
# Build outputs
# ---------------------
dist/
build/
.next/
out/
.nuxt/
.output/
.vercel/
.netlify/
.parcel-cache/
.turbo/
.cache/

# ---------------------
# Dependencies
# ---------------------
node_modules/
.pnpm-store/
vendor/
__pycache__/
*.pyc
.venv/
venv/
.eggs/
*.egg-info/

# ---------------------
# Generated / minified files
# ---------------------
*.min.js
*.min.css
*.map
*.chunk.*
*.bundle.*

# ---------------------
# Test coverage
# ---------------------
coverage/
.nyc_output/
htmlcov/
.coverage

# ---------------------
# Lock files
# ---------------------
package-lock.json
yarn.lock
pnpm-lock.yaml
Pipfile.lock
poetry.lock
Gemfile.lock
composer.lock

# ---------------------
# Media and font assets
# ---------------------
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.mp4
*.mp3
*.webm
*.webp
*.woff
*.woff2
*.ttf
*.eot

# ---------------------
# IDE and OS files
# ---------------------
.idea/
.vscode/*
!.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------------------
# Docker
# ---------------------
docker-volumes/
.docker/

# ---------------------
# Logs
# ---------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------
# Test snapshots & fixtures
# ---------------------
**/__snapshots__/
**/fixtures/large/
*.snap

# ---------------------
# Database files
# ---------------------
*.sqlite
*.sqlite3
*.db

# ---------------------
# Terraform state
# ---------------------
*.tfstate
*.tfstate.backup
.terraform/

# ---------------------
# Miscellaneous temp files
# ---------------------
tmp/
temp/
*.tmp
*.bak
*.pid
