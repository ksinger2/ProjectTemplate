{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(npm test*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npx prettier*)",
      "Bash(npx eslint*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in **/migrations/**|**/.env*|**/auth/**|**/payment/**) echo '⚠️  Editing sensitive file — ensure security review' ;; esac; exit 0"
          }
        ]
      }
    ]
  }
}
